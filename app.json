        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "scheme": "hooper",
    "extra": {
      "eas": {
        "projectId": "0d004a05-6825-40ab-8640-f2567d841f31"
      }
    },
    "owner": "hoop33-dev",
    "plugins": ["expo-router", "expo-font"]
