{
  "name": "hooper",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "types": "supabase gen types typescript --linked > src/lib/database.types.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "expo lint --fix"
    ],
    "*.{js,json,css,md}": "prettier --write"
  },
  "dependencies": {
    "@expo-google-fonts/lexend": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-linear-gradient": "^55.0.11",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "^55.0.15",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.16",
    "nativewind": "^5.0.0-preview.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css": "^3.0.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-native-ai-devtools": "^1.3.7",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
